      ],
      "description": "Example generated by Copilot GPT-5.4. UPSA constructs monthly factor-portfolio weights by combining ridge portfolios with non-negative ensemble weights and applying the resulting factor weights with a one-period lag.",
      "plan_id": "plan_1",
      "strategy_id": "upsa",
      "backtest_id": "jkp_monthly_factor_returns",
      "price_data": false,
      "volume_data": false,
      "fundamental_data": [],
      "alternative_data": [],
      "lookback_period": 120,
      "data_frequency": "monthly",
