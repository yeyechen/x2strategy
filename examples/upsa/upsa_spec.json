      "time_period": "Rolling 120-month training windows; OOS begins after the first full window",
      "universe_assets": [
        "JKP factor portfolios"
      ],
      "universe_selection_criteria": "All factor return columns in the confirmed wide panel, excluding the date column.",
      "expected_sharpe": null,
