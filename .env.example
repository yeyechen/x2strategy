# x2strategy — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and loaded automatically.

# ── LLM Model ──
PAPER2SPEC_MODEL=deepseek/deepseek-chat

# ── Output Library ──
# Default root used by scripts/analyze.py and scripts/parse.py
PAPER2SPEC_LIBRARY_PATH=/absolute/path/to/library

# ── Init Marker ──
# Set after first successful setup. Agent can use this as a quick signal,
# but should still verify required keys/path at runtime.
PAPER2SPEC_INIT_VERSION=1

# ── API Keys (set the one matching your model provider) ──
DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Custom OpenAI-compatible endpoint (e.g. local vLLM) ──
# OPENAI_API_BASE=http://localhost:8000/v1

# ── Optional: Search Tuning (429/5xx resilience) ──
# PAPER2SPEC_ARXIV_MIN_INTERVAL=3.0
# PAPER2SPEC_SEARCH_MAX_RETRIES=3
# PAPER2SPEC_SEARCH_TIMEOUT_SECONDS=30

# ── Spec2Code Settings ──
# SPEC2CODE_BACKTEST_TIMEOUT=300
# SPEC2CODE_DATA_CACHE=/absolute/path/to/data_cache
